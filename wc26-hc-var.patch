+    ck("the result bet WON off the shootout", res_bet.get("status") == "won", res_bet)
+finally:
+    S.stop()
+
+print()
+if FAILS:
+    print("FAILED: %d -> %s" % (len(FAILS), FAILS))
+    raise SystemExit(1)
