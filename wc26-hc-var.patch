+api_deep = [{"id": 11, "homeTeam": {"name": "A", "lineup": [{"name": "Keeper One", "position": "Goalkeeper", "shirtNumber": 1},
+                                                            {"name": "Back Two", "position": "Defence", "shirtNumber": 2}]},
+             "awayTeam": {"name": "B", "lineup": []},
