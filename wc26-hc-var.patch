+    ck("every served hc book is margined (complete 3-way overrounds; partial lines allowed)",
+       all((sum(1.0 / v[x]["decimal"] for x in ("HOME", "DRAW", "AWAY")) > 1.0 + 1e-6)
+           if all(x in v for x in ("HOME", "DRAW", "AWAY")) else bool(v) for v in hc.values()), hc)
