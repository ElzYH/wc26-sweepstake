diff --git a/qa_hc_exploit.py b/qa_hc_exploit.py
new file mode 100644
index 0000000..cfd7a68
--- /dev/null
+++ b/qa_hc_exploit.py
@@ -0,0 +1,125 @@
+#!/usr/bin/env python3
+"""Handicap exploit sweep — proves the new book can't be farmed, alone or in combination.
+(1) Per-side EV floor: on every offered side, rounded implied >= fair (no long-run bettor-positive rung).
+(2) Analytic covering dutches: every 2-leg combination that COVERS all outcomes — hc x 1X2 across the two
+    different probability models (group 3-way AND the knockout 2-way advance book, where a shootout can
+    decide the result leg), and hc x hc across lines — must cost more than 1.0 implied. These are the exact
+    baskets a sharp bettor would try, priced from the books the server actually serves.
+(3) Seeded dutch fuzz: 4000 random baskets of <=3 legs across result/OU/handicap/exact-score; the
+    worst-case winning-leg count over the outcome space never exceeds the basket's implied cost, so no
+    basket is a guaranteed profit. Deterministic seed -> a stable gate."""
+import random
+import wager as W
+
+fails = []
+def ck(name, cond, extra=""):
+    print(("  PASS " if cond else "  FAIL ") + name + ("" if cond or extra == "" else "  -> %r" % (extra,)))
+    if not cond:
+        fails.append(name)
+
+COMPS = [(c1, c2) for c1 in range(0, 101, 10) for c2 in range(0, 101, 10)]
+
+print("== (1) per-side EV floor: implied >= fair on every offered handicap side ==")
+bad = []
+for c1, c2 in COMPS:
+    lh, la = W._team_lambdas(c1, c2)
+    for k, leg in W.hc_odds(c1, c2).items():
+        fair_h = W._hc_home_prob(lh, la, float(k))
+        for sel, fair in (("HOME", fair_h), ("AWAY", 1.0 - fair_h)):
+            if sel not in leg:
+                if fair <= W.HC_MAX_PROB - 1e-9:
+                    bad.append((c1, c2, k, sel, "safe side missing"))   # only a capped near-certainty may be dropped
+                continue
+            if 1.0 / leg[sel]["decimal"] < fair - 1e-9:
+                bad.append((c1, c2, k, sel, 1.0 / leg[sel]["decimal"], fair))
+ck("no rounded side ever pays better than fair (121 strength pairs)", not bad, bad[:4])
+
+print("\n== (2) analytic covering dutches always cost > 1.0 implied ==")
+def covers_all_hc_1x2(key, hc_sel):
+    # hc HOME@key wins margin > -key; hc AWAY@key wins margin < -key (half keys: exact complement)
+    # HOME(1x2) covers margin >= 1 ... AWAY(1x2) covers margin <= -1 (a KO 'advance' side covers at least that)
+    return ("HOME_1X2",) if (hc_sel == "AWAY" and key < 0) else (("AWAY_1X2",) if (hc_sel == "HOME" and key > 0) else ())
+worst = None
+for c1, c2 in COMPS:
+    hc = W.hc_odds(c1, c2)
+    for ko in (False, True):
+        mo = W.match_odds(c1, c2, knockout=ko)
+        for k, leg in hc.items():
+            key = float(k)
+            for hc_sel in ("HOME", "AWAY"):
+                if hc_sel not in leg:
+                    continue                          # one-sided line: that side isn't for sale
+                for partner in covers_all_hc_1x2(key, hc_sel):
+                    part = mo["HOME"] if partner == "HOME_1X2" else mo["AWAY"]
+                    cost = 1.0 / leg[hc_sel]["decimal"] + 1.0 / part["decimal"]
+                    if worst is None or cost < worst[0]:
+                        worst = (cost, c1, c2, k, hc_sel, partner, "KO" if ko else "GRP")
+                    if cost <= 1.0 + 1e-9:
+                        fails.append("hc x 1X2 cover under 1.0 at %r" % ((c1, c2, k, hc_sel, partner, ko),))
+ck("every covering hc x 1X2 dutch (group AND knockout books) costs > 1.0", 
+   not any(f.startswith("hc x 1X2") for f in fails), worst)
+print("     tightest hc x 1X2 cover found: %.4f implied at comps (%d,%d) line %s %s + %s [%s]" % worst)
+
+worst2 = None
+for c1, c2 in COMPS:
+    hc = W.hc_odds(c1, c2)
+    keys = sorted((float(k) for k in hc), reverse=True)
+    for L1 in keys:              # HOME@L1 wins m > -L1 ; AWAY@L2 wins m < -L2 ; union covers all <=> L2 < L1
+        for L2 in keys:
+            if L2 < L1:
+                l1, l2 = hc[W._line_key(L1)], hc[W._line_key(L2)]
+                if "HOME" not in l1 or "AWAY" not in l2:
+                    continue                          # can't buy a side that isn't offered
+                cost = 1.0 / l1["HOME"]["decimal"] + 1.0 / l2["AWAY"]["decimal"]
+                if worst2 is None or cost < worst2[0]:
+                    worst2 = (cost, c1, c2, L1, L2)
+                if cost <= 1.0 + 1e-9:
+                    fails.append("hc x hc cover under 1.0 at %r" % ((c1, c2, L1, L2),))
+ck("every covering hc x hc dutch costs > 1.0", not any(f.startswith("hc x hc") for f in fails), worst2)
+print("     tightest hc x hc cover found: %.4f implied at comps (%d,%d) HOME@%+g + AWAY@%+g" % worst2)
+
+print("\n== (3) seeded dutch fuzz across ALL four markets: no basket guarantees profit ==")
+rng = random.Random(26)
+OUTCOMES = [(h, a) for h in range(10) for a in range(10)] + [(12, 0), (0, 12), (12, 5), (5, 12)]
+def leg_wins(leg, h, a):
+    kind = leg[0]
+    if kind == "res":
+        m = h - a
+        return (m > 0) if leg[1] == "HOME" else ((m < 0) if leg[1] == "AWAY" else m == 0)
+    if kind == "ou":
+        return (h + a) > leg[2] if leg[1] == "OVER" else (h + a) < leg[2]
+    if kind == "hc":
+        cov = (h + leg[2]) > a
+        return cov if leg[1] == "HOME" else not cov
+    return "%d-%d" % (h, a) == leg[1]                       # cs
+checked = 0
+for _ in range(4000):
+    c1, c2 = rng.choice(COMPS)
+    pool = []
+    mo = W.match_odds(c1, c2)
+    for sel in ("HOME", "DRAW", "AWAY"):
+        pool.append((("res", sel), 1.0 / mo[sel]["decimal"]))
+    for k, leg in W.goals_odds(c1, c2).items():
+        for sel in ("OVER", "UNDER"):
+            pool.append((("ou", sel, float(k)), 1.0 / leg[sel]["decimal"]))
+    for k, leg in W.hc_odds(c1, c2).items():
+        for sel in ("HOME", "AWAY"):
+            if sel in leg:
+                pool.append((("hc", sel, float(k)), 1.0 / leg[sel]["decimal"]))
+    cs = W.cs_odds(c1, c2)
+    for cell in rng.sample(sorted(cs), 12):
+        pool.append((("cs", cell), 1.0 / cs[cell]["decimal"]))
+    basket = rng.sample(pool, rng.randint(1, 3))
+    implied = sum(p for _leg, p in basket)
+    min_wins = min(sum(1 for leg, _p in basket if leg_wins(leg, h, a)) for h, a in OUTCOMES)
+    checked += 1
+    if min_wins > implied + 1e-9:
+        fails.append("guaranteed-profit basket at (%d,%d): %r" % (c1, c2, basket))
+ck("4000 random <=3-leg baskets: worst-case wins never exceed the implied cost", 
+   not any(f.startswith("guaranteed-profit") for f in fails), checked)
+
+print()
+if fails:
+    print("FAILED: %d -> %s" % (len(fails), fails[:6]))
+    raise SystemExit(1)
+print("ALL HANDICAP EXPLOIT CHECKS PASSED")
